<?xml version="1.0" encoding="utf-8"?><!--
Solid white circle used as the calendar event marker. It is drawn into an
ImageView and tinted to each event's calendar color at runtime via
setColorFilter (see CalendarRemoteViewsService). A white fill is required so
the color filter reproduces the true event color.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#ffffff" />
</shape>
