<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tone_label"
            android:textStyle="bold"
            android:paddingTop="8dp" />

        <RadioGroup
            android:id="@+id/tone_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/tone_wallpaper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tone_wallpaper" />

            <RadioButton
                android:id="@+id/tone_neutral"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tone_neutral" />

            <RadioButton
                android:id="@+id/tone_white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tone_white" />
        </RadioGroup>

        <Switch
            android:id="@+id/switch_clock_only"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:text="@string/clock_only" />

        <Switch
            android:id="@+id/switch_weather"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="@string/show_weather" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/unit_label"
            android:textStyle="bold"
            android:paddingTop="16dp" />

        <RadioGroup
            android:id="@+id/unit_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/unit_celsius"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="@string/unit_celsius" />

            <RadioButton
                android:id="@+id/unit_fahrenheit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/unit_fahrenheit" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/weather_app_label"
            android:textStyle="bold"
            android:paddingTop="16dp" />

        <Button
            android:id="@+id/btn_weather_app"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/weather_app_choose" />

        <Button
            android:id="@+id/btn_done"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/done" />

    </LinearLayout>

</ScrollView>
