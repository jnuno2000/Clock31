<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calendar_entry"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    >

    <!--
    Solid, rounded color block behind the text. The white shape is tinted to the
    event's calendar color at runtime (setColorFilter), so each event looks like a
    Google-Calendar colored chip.
    -->
    <ImageView
        android:id="@+id/block_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/event_block"
        android:contentDescription="@null"
        />

    <!--
    Title and time are ImageViews holding bitmaps rendered in Google Sans
    (CalendarRemoteViewsService), because widget text views can't use custom fonts.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="9dp"
        android:paddingBottom="9dp"
        >

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/event_title"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/event_date"
            android:adjustViewBounds="true"
            android:layout_marginTop="1dp"
            android:contentDescription="@null"
            />

    </LinearLayout>

</FrameLayout>
