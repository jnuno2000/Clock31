<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calendar_entry"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    >

    <!--
    Solid, rounded color block behind the text. The white shape is tinted to the
    event's calendar color at runtime (setColorFilter), so each event looks like a
    Google-Calendar colored chip. The text color is chosen for contrast in code.
    -->
    <ImageView
        android:id="@+id/block_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/event_block"
        android:contentDescription="@null"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        >

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/event_title"
            android:text="Event title"
            android:textColor="#ffffff"
            android:textSize="14dp"
            android:textFontWeight="500"
            android:maxLines="1"
            android:ellipsize="end"
            android:shadowColor="#66000000"
            android:shadowRadius="2.5"
            android:shadowDx="0"
            android:shadowDy="1"
            />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/event_date"
            android:text="From - To"
            android:textColor="#e0ffffff"
            android:textSize="12dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="1dp"
            android:shadowColor="#66000000"
            android:shadowRadius="2.5"
            android:shadowDx="0"
            android:shadowDy="1"
            />

    </LinearLayout>

</FrameLayout>
